-- Vị trí Mirror Fractal
local MirrorFractalPos = Vector3.new(-12400, 10, 10800)

-- Auto V4 Helper
local function AutoV4Function()
    while State.AutoV4 do
        if State.V4Step == 1 then
            -- Step 1: Farm Fragment từ Elite Mobs
            for _, mob in pairs(Workspace.Enemies:GetChildren()) do
                local name = mob.Name:lower()
                if name:find("elite") and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                    AttackMob(mob)
                    task.wait(0.3)
                end
            end
            
        elseif State.V4Step == 2 then
            -- Step 2: Auto lấy Gear
            for gearName, gearPos in pairs(GearLocations) do
                TeleportTo(gearPos)
                task.wait(1)
                -- Tương tác để lấy gear
                pcall(function()
                    local args = {[1] = "GetGear", [2] = gearName}
                    ReplicatedStorage.Remotes.CommF_:InvokeServer("Server", "GetGear", args)
                end)
                task.wait(2)
            end
            
        elseif State.V4Step == 3 then
            -- Step 3: Mirror Fractal
            TeleportTo(MirrorFractalPos)
            task.wait(1)
            pcall(function()
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Server", "MirrorFractal", {})
            end)
            task.wait(5)
            
        elseif State.V4Step == 4 then
            -- Step 4: Trail và Awakening
            pcall(function()
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Server", "StartTrail", {})
                task.wait(10)
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Server", "AwakenV4", {})
            end)
        end
        
        task.wait(2)
    end
end


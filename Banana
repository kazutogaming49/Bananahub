-- ESP (Nhìn xuyên tường, hiển thị vị trí)
local function CreateESP()
    while State.ESP do
        -- Xóa ESP cũ
        for _, v in pairs(espObjects) do
            pcall(function() v:Destroy() end)
        end
        espObjects = {}
        
        -- Tạo ESP cho quái vật
        if State.ESPType == "Mobs" or State.ESPType == "All" then
            for _, mob in pairs(Workspace.Enemies:GetChildren()) do
                if mob:FindFirstChild("HumanoidRootPart") then
                    local billboard = Instance.new("BillboardGui")
                    billboard.Size = UDim2.new(0, 100, 0, 40)
                    billboard.StudsOffset = Vector3.new(0, 3, 0)
                    billboard.AlwaysOnTop = true
                    billboard.Parent = mob.HumanoidRootPart
                    
                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(1, 0, 1, 0)
                    label.BackgroundTransparency = 1
                    label.Text = "🐱 " .. mob.Name
                    label.TextColor3 = Color3.fromRGB(255, 100, 100)
                    label.TextStrokeTransparency = 0.3
                    label.TextScaled = true
                    label.Parent = billboard
                    
                    table.insert(espObjects, billboard)
                end
            end
        end
        
        -- Tạo ESP cho Fruit
        if State.ESPType == "Fruits" or State.ESPType == "All" then
            for _, fruit in pairs(Workspace:GetChildren()) do
                if fruit.Name:find("Fruit") or fruit:FindFirstChild("Fruit") then
                    local billboard = Instance.new("BillboardGui")
                    billboard.Size = UDim2.new(0, 80, 0, 30)
                    billboard.StudsOffset = Vector3.new(0, 2, 0)
                    billboard.AlwaysOnTop = true
                    billboard.Parent = fruit
                    
                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(1, 0, 1, 0)
                    label.BackgroundTransparency = 1
                    label.Text = "🍎 " .. fruit.Name
                    label.TextColor3 = Color3.fromRGB(100, 255, 100)
                    label.TextScaled = true
                    label.Parent = billboard
                    
                    table.insert(espObjects, billboard)
                end
            end
        end
        
        task.wait(0.5)
    end
    
    -- Xóa ESP khi tắt
    for _, v in pairs(espObjects) do
        pcall(function() v:Destroy() end)
    end
    espObjects = {}
end


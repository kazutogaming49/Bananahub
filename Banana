-- 3.1 Auto Farm Mobs thường
local function AutoFarmMobs()
    while State.AutoFarm and State.FarmTarget == "Mobs" do
        local mob = GetNearestMob()
        if mob then
            AttackMob(mob)
        end
        task.wait(0.1)
    end
end

-- 3.2 Auto Farm Kitsune Island (Chuyên sâu)
local function AutoFarmKitsune()
    while State.AutoKitsune do
        -- Kiểm tra nếu chưa ở Kitsune Island thì teleport
        local kitsuneIslandPos = Vector3.new(-14500, 150, 12500)
        if (RootPart.Position - kitsuneIslandPos).Magnitude > 500 then
            TeleportToIsland("Kitsune Island")
            task.wait(1)
        end
        
        -- Tìm Kitsune
        local kitsune = GetNearestKitsune()
        if kitsune then
            AttackMob(kitsune)
        else
            -- Di chuyển vòng quanh đảo để tìm
            local waypoints = {
                Vector3.new(-14500, 150, 12500),
                Vector3.new(-14300, 145, 12700),
                Vector3.new(-14700, 155, 12300),
                Vector3.new(-14200, 140, 12400),
                Vector3.new(-14600, 160, 12600)
            }
            for _, wp in pairs(waypoints) do
                TeleportTo(wp)
                task.wait(0.5)
            end
        end
        task.wait(0.2)
    end
end

-- 3.3 Auto Farm Bone (Halloween Event)
local function AutoFarmBone()
    while State.AutoBone do
        -- Teleport đến Haunted Castle nếu cần
        local hauntedPos = Vector3.new(-11500, 200, 9800)
        if (RootPart.Position - hauntedPos).Magnitude > 500 then
            TeleportToIsland("Haunted Castle")
            task.wait(1)
        end
        
        -- Tìm quái vật farm Bone
        local boneMob = GetNearestBoneMob()
        if boneMob then
            AttackMob(boneMob)
        else
            -- Di chuyển quanh Haunted Castle
            TeleportTo(hauntedPos)
        end
        task.wait(0.15)
    end
end

-- 3.4 Auto Quest (Nhận và hoàn thành quest tự động)
local function AutoQuestFunction()
    while State.AutoQuest do
        pcall(function()
            -- Nhận quest từ NPC gần nhất
            local args = {[1] = "StartQuest", [2] = State.SelectedIsland}
            ReplicatedStorage.Remotes.CommF_:InvokeServer("Server", "StartQuest", args)
            
            -- Check quest completion
            local args2 = {[1] = "GetQuest"}
            local quest = ReplicatedStorage.Remotes.CommF_:InvokeServer("Server", "GetQuest", args2)
            
            if quest and quest.Completed then
                local args3 = {[1] = "ClaimQuest"}
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Server", "ClaimQuest", args3)
            end
        end)
        task.wait(10)
    end
end


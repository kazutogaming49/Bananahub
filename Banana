-- Tìm Sea Beast
local function FindSeaBeast()
    for _, obj in pairs(Workspace:GetChildren()) do
        local name = obj.Name:lower()
        if name:find("seabeast") or name:find("sea beast") or obj:FindFirstChild("SeaBeast") then
            return obj
        end
    end
    return nil
end

-- Tìm Ship Raid
local function FindShipRaid()
    for _, obj in pairs(Workspace:GetChildren()) do
        local name = obj.Name:lower()
        if (name:find("ship") or name:find("boat")) and obj:FindFirstChild("Humanoid") then
            return obj
        end
    end
    return nil
end

-- Tìm Terror Shark
local function FindTerrorShark()
    for _, obj in pairs(Workspace:GetChildren()) do
        local name = obj.Name:lower()
        if name:find("terror") or name:find("shark") then
            return obj
        end
    end
    return nil
end

-- Auto Sea Event chính
local function AutoSeaEventFunction()
    while State.AutoSeaEvent do
        local target = nil
        
        if State.SeaEventType == "Sea Beast" or State.SeaEventType == "All" then
            target = FindSeaBeast()
        end
        
        if not target and (State.SeaEventType == "Ship Raid" or State.SeaEventType == "All") then
            target = FindShipRaid()
        end
        
        if not target and (State.SeaEventType == "Terror Shark" or State.SeaEventType == "All") then
            target = FindTerrorShark()
        end
        
        if target and target:FindFirstChild("HumanoidRootPart") then
            AttackMob(target)
            TeleportTo(target.HumanoidRootPart.Position + Vector3.new(0, 15, 0))
        end
        
        task.wait(0.3)
    end
end


-- Hàm tìm quái vật gần nhất (Mobs thường)
local function GetNearestMob()
    local nearest = nil
    local minDist = math.huge
    
    for _, mob in pairs(Workspace.Enemies:GetChildren()) do
        if mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
            local hrp = mob:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (RootPart.Position - hrp.Position).Magnitude
                if dist < minDist and dist < 400 then
                    minDist = dist
                    nearest = mob
                end
            end
        end
    end
    return nearest
end

-- Hàm tìm Kitsune (quái vật đặc biệt ở Kitsune Island)
local function GetNearestKitsune()
    local nearest = nil
    local minDist = math.huge
    
    for _, mob in pairs(Workspace.Enemies:GetChildren()) do
        local name = mob.Name:lower()
        if name:find("kitsune") or name:find("fox") or name:find("nine") then
            if mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                local hrp = mob:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (RootPart.Position - hrp.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = mob
                    end
                end
            end
        end
    end
    return nearest
end

-- Hàm tìm quái vật farm Bone (Halloween)
local function GetNearestBoneMob()
    local nearest = nil
    local minDist = math.huge
    
    for _, mob in pairs(Workspace.Enemies:GetChildren()) do
        local name = mob.Name:lower()
        if name:find("skeleton") or name:find("ghost") or name:find("pumpkin") or name:find("bone") then
            if mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                local hrp = mob:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (RootPart.Position - hrp.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = mob
                    end
                end
            end
        end
    end
    return nearest
end

-- Hàm tấn công quái vật
local function AttackMob(mob)
    if mob and mob:FindFirstChild("HumanoidRootPart") then
        local args = {[1] = mob}
        local success, err = pcall(function()
            ReplicatedStorage.Remotes.CommF_:InvokeServer("Server", "Attack", args)
        end)
        if not success then
            -- Thử cách khác nếu remote khác
            pcall(function()
                ReplicatedStorage.Remotes.Comm_:InvokeServer("Attack", mob)
            end)
        end
    end
end

